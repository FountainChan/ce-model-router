{
    "$schema": "https://opencode.ai/config.json",
    "plugin": ["opencode-runtime-fallback"],
    "mcp": {
        "context7": {
            "type": "remote",
            "url": "https://mcp.context7.com/mcp",
            "enabled": true
        }
    },
    "disabled_providers": [],
    "small_model": "zhipuai-coding-plan/glm-4.5-air",
    "provider": {
        "yunwu-claude": {
            "options": {
                "apiKey": "YOUR_API_KEY_HERE",
                "baseURL": "https://yunwu.ai/v1/"
            },
            "models": {
                "claude-opus-4-7": {
                    "name": "Claude Opus 4.7",
                    "limit": {
                        "context": 200000,
                        "output": 64000
                    }
                }
            }
        },
        "yunwu-gpt": {
            "options": {
                "apiKey": "YOUR_API_KEY_HERE",
                "baseURL": "https://yunwu.ai/v1/"
            },
            "models": {
                "gpt-5.4": {
                    "name": "GPT-5.4",
                    "limit": {
                        "context": 128000,
                        "output": 16384
                    }
                }
            }
        },
        "zhipuai": {
            "options": {
                "apiKey": "YOUR_API_KEY_HERE",
                "baseURL": "https://api.z.ai/api/paas/v4/"
            },
            "models": {
                "glm-4.7": {
                    "name": "zhipuai - GLM 4.7",
                    "limit": {
                        "context": 200000,
                        "output": 128000
                    }
                }
            }
        },
        "openrouter": {
            "models": {
                "z-ai/glm-5": {},
                "anthropic/claude-opus-4-7": {},
                "deepseek/deepseek-r1-0528": {}
            }
        },
        "zhipuai-coding-plan": {
            "options": {
                "apiKey": "YOUR_API_KEY_HERE"
            }
        }
    },
    "experimental": {
        "modelFallbackChain": {
            "timeoutMs": 60000,
            "chains": [
                ["minimax-cn-coding-plan/MiniMax-M2.7", "zhipuai-coding-plan/glm-5.1"],
                ["zhipuai-coding-plan/glm-5.1", "opencode-go/deepseek-v4-pro", "yunwu-claude/claude-opus-4-7"],
                ["yunwu-claude/claude-opus-4-7", "yunwu-gpt/gpt-5.4"]
            ]
        }
    }
}
